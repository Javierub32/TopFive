{
  "expo": {
    "name": "TopFive",
    "slug": "topfive",
    "version": "1.3.1",
    "scheme": "topfive",
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro",
      "output": "single",
      "build": {
        "babel": {
          "include": [
            "@expo/vector-icons"
          ]
        }
      }
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker",
	    [
          "expo-tracking-transparency",
          {
            "userTrackingPermission": "Esta aplicación utiliza el identificador de tu dispositivo para mostrarte anuncios relevantes y personalizados."
          }
        ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2120812527357725~2420909779",
          "iosAppId": "ca-app-pub-2120812527357725~1614588357",
          "userTrackingPermission": "Esta aplicación utiliza el identificador de tu dispositivo para mostrarte anuncios relevantes y personalizados."
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#5781b3"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/ios_icon.png",
      "bundleIdentifier": "com.leftjoiners.topfive",
      "buildNumber": "1",
      "associatedDomains": [
        "applinks:www.topfive5.me",
        "applinks:topfive5.me"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.1045116527499-u3kj7uo06ar23im0rqg9ltis3e8rfa37"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5781b3"
      },
      "package": "com.leftjoiners.topfive",
      "permissions": [
        "com.google.android.gms.permission.AD_ID"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.topfive5.me"
            },
            {
              "scheme": "https",
              "host": "topfive5.me"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "versionCode": 1
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7793291a-d63c-43ed-8a35-34f8cc7a863e"
      }
    }
  }
}
