{
  "headers": [
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/details/user",
      "destination": "/api/og-profile"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}